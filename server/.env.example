# CityShield Server Environment Variables
# Copy this file to .env and fill in your API keys.
# The server works fully without any keys using built-in fallback data.

# ---------------------------------------------------------------------------
# External API Keys (all optional — server uses fallback data if not set)
# ---------------------------------------------------------------------------

# NewsAPI key — get one free at https://newsapi.org
NEWSAPI_KEY=

# Alpha Vantage key — get one free at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# Twilio credentials — for real SMS dispatch
TWILIO_SID=
TWILIO_AUTH=

# ---------------------------------------------------------------------------
# Flask Settings
# ---------------------------------------------------------------------------
FLASK_SECRET=your_secret_key_here_change_in_production
DEBUG=True

# ---------------------------------------------------------------------------
# API Base URLs (defaults shown — only change if using proxies)
# ---------------------------------------------------------------------------
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc
NEWSAPI_BASE_URL=https://newsapi.org/v2/everything
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

# ---------------------------------------------------------------------------
# Cache TTLs (seconds)
# ---------------------------------------------------------------------------
NEWS_CACHE_TTL=900
OIL_CACHE_TTL=1800

# ---------------------------------------------------------------------------
# City / Scheduler config
# ---------------------------------------------------------------------------
CITY=Pune
COUNTRY_CODE=IN
REFRESH_INTERVAL_MINUTES=15
